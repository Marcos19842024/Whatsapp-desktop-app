{
  "name": "whatsapp-desktop-app",
  "version": "1.0.0",
  "description": "Sistema de envío de WhatsApp con interfaz Windows",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "tsc && npm run build-renderer",
    "build-renderer": "webpack --mode production",
    "build-electron": "tsc -p tsconfig.main.json",
    "watch": "webpack --watch --mode development",
    "start": "electron .",
    "dev": "npm run build && npm run start",
    "dev:mac": "ELECTRON_ENABLE_LOGGING=1 npm run dev",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --x64",
    "dist:win-portable": "npm run build && electron-builder --win portable --x64",
    "dist:mac": "npm run build && electron-builder --mac",
    "clean": "rm -rf dist release logs"
  },
  "build": {
    "appId": "com.whatsapp.desktop",
    "productName": "WhatsApp Reminder System",
    "copyright": "Copyright © 2024",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "data/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.exe"
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "electron": "^27.0.0",
    "moment": "^2.29.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^15.0.0",
    "react-toastify": "^9.1.3",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.14.0",
    "@mui/material": "^5.14.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/react-dropzone": "^4.2.2",
    "@types/xlsx": "^0.0.36",
    "concurrently": "^8.2.2",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.8.1",
    "electron-builder": "^24.6.4",
    "nodemon": "^3.0.1",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.2.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
